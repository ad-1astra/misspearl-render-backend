# ─────────────────────────────────────────────────────────
# AI PROVIDER SELECTION
# ─────────────────────────────────────────────────────────
# Choose which AI backend to use by default
# Options: "ollama" (local) or "pearl" (cloud OpenAI-compatible)
# NOTE: Clients can override via the "provider" parameter in /chat requests
AI_PROVIDER=pearl

# ─────────────────────────────────────────────────────────
# OLLAMA CONFIGURATION (Local LLM)
# ─────────────────────────────────────────────────────────
# Uncomment and modify if running Ollama on a different host/port
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ─────────────────────────────────────────────────────────
# PEARL AI HUB CONFIGURATION (OpenAI-Compatible API)
# ─────────────────────────────────────────────────────────
# Pearl Labs hosted AI inference service with OpenAI-compatible endpoints
# This allows the AI to access cloud-based models including OpenAI knowledge

# Pearl API Base URL (no trailing slash)
PEARL_API_BASE_URL=https://apps.pearllabs.ug

# Pearl API Authentication Token (Bearer token)
# This connects the app to OpenAI and other cloud models via Pearl Labs
PEARL_API_KEY=pearl__k3zN-ihPfuTfWeiNMcXDDpCogbCcJSGnZi2yK_dT64

# Model to use from Pearl API Hub (qwen is the default)
PEARL_MODEL=qwen

